# Start with Google Cloud SDK (includes gcloud)
FROM google/cloud-sdk:alpine

# Install OpenJDK 21 (needed to run Maven and JUnit)
RUN apk add --no-cache openjdk21

WORKDIR /app

# Copy Maven wrapper and configuration
COPY .mvn/ .mvn/
COPY mvnw pom.xml ./
RUN chmod +x mvnw

# Download dependencies (go-offline) to speed up subsequent runs
RUN ./mvnw dependency:go-offline

# Copy source code (including the new IntegrationTest.java)
COPY src ./src

# Run the tests using Maven
# We use -Dtest=IntegrationTest to specifically run our new test class
ENTRYPOINT ["./mvnw", "test", "-Dtest=IntegrationTest"]